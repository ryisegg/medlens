# Required by api/symptom-advice.ts and api/translate.ts in Vercel or another serverless host.
OPENAI_API_KEY=

# Optional. Override the default OpenAI model used by the backend.
OPENAI_MODEL=gpt-4o-mini

# Optional. Restrict browser origins allowed to call the AI and translation APIs.
# Example: https://ryisegg.github.io
ALLOWED_ORIGIN=

# Optional for frontend builds hosted on GitHub Pages.
# Set these to your deployed backend URLs, for example:
# VITE_AI_API_URL=https://medlens-yourname.vercel.app/api/symptom-advice
# VITE_TRANSLATE_API_URL=https://medlens-yourname.vercel.app/api/translate
VITE_AI_API_URL=
VITE_TRANSLATE_API_URL=
