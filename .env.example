# App URL used by billing redirects and backend status.
APP_URL=https://ryisegg.github.io/medlens

# Optional. Restrict browser origins allowed to call the APIs.
# Example: https://ryisegg.github.io
ALLOWED_ORIGIN=https://ryisegg.github.io

# AI symptom guidance and medical translation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Frontend API base. Use this when the frontend is hosted on GitHub Pages
# and the backend is deployed on Vercel or another serverless host.
# Example: VITE_API_BASE_URL=https://medlens-yourname.vercel.app
VITE_API_BASE_URL=

# Backward-compatible one-off endpoint overrides. Prefer VITE_API_BASE_URL for new deploys.
VITE_AI_API_URL=
VITE_TRANSLATE_API_URL=

# Supabase account/auth foundation for the next account-sync phase.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe subscription checkout foundation for future paid plans.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
