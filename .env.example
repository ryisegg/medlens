# Required by api/symptom-advice.ts in Vercel or another serverless host.
OPENAI_API_KEY=

# Optional. Override the default OpenAI model used by the backend.
OPENAI_MODEL=gpt-4.1-mini

# Optional. Restrict browser origins allowed to call the AI API.
# Example: https://ryisegg.github.io
ALLOWED_ORIGIN=

# Optional for frontend builds hosted on GitHub Pages.
# Set this to your deployed backend URL, for example:
# VITE_AI_API_URL=https://medlens-yourname.vercel.app/api/symptom-advice
VITE_AI_API_URL=
